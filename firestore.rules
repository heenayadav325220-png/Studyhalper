rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // Test collection for connection validation
    match /test/{docId} {
      allow read, write: if true;
    }

    // Users collection and sub-collections
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }

      match /schedule/{scheduleId} {
        allow read, write: if isOwner(userId);
      }

      match /progress/{progressId} {
        allow read, write: if isOwner(userId);
      }

      match /flashcards/{cardId} {
        allow read, write: if isOwner(userId);
      }

      match /diagrams/{diagramId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Group membership checker
    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // Groups collection
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.created_by == request.auth.uid || isGroupMember(groupId));

      // Sub-collections inside study groups
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (memberId == request.auth.uid || isGroupMember(groupId));
      }

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
      }

      match /notes/{noteId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.asked_by == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && resource.data.asked_by == request.auth.uid;
      }

      match /sessions/{sessionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.created_by == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && resource.data.created_by == request.auth.uid;
      }
    }
  }
}
