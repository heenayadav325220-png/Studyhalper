{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores student profile information, points, level, and companion pet state.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user authentication ID." },
        "name": { "type": "string", "description": "Name of the student." },
        "school": { "type": "string", "description": "School of the student." },
        "className": { "type": "string", "description": "The grade or class level of the student." },
        "points": { "type": "integer", "description": "Gamification points earned." },
        "level": { "type": "integer", "description": "Current educational level." },
        "avatar": { "type": "string", "description": "Elected emoji or icon avatar representing the student." },
        "badges": { "type": "array", "description": "Array of unlocked achievement badges." },
        "pet": { "type": "object", "description": "The state of the student's virtual companion pet." }
      },
      "required": ["uid", "name", "school", "className"]
    },
    "Note": {
      "title": "Student Note",
      "description": "A single personal notebook note.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the note." },
        "title": { "type": "string", "description": "Title of the note." },
        "content": { "type": "string", "description": "Rich text or markdown content of the note." },
        "subject": { "type": "string", "description": "Academic subject category of the note." },
        "updated_at": { "type": "string", "format": "date-time", "description": "Last updated timestamp." },
        "interval": { "type": "integer", "description": "Current spaced repetition review interval in days." },
        "repetition": { "type": "integer", "description": "Consecutive successful spaced repetition reviews." },
        "easeFactor": { "type": "number", "description": "Spaced repetition difficulty multiplier factor." },
        "nextReviewDate": { "type": "string", "format": "date-time", "description": "Scheduled timestamp for the next review." },
        "lastReviewedDate": { "type": "string", "format": "date-time", "description": "Timestamp when this note was last reviewed." }
      },
      "required": ["id", "title", "subject", "updated_at"]
    },
    "ScheduleItem": {
      "title": "Schedule Planner Item",
      "description": "An entry in the student's homework planner calendar.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the task." },
        "task": { "type": "string", "description": "Task or homework description." },
        "time": { "type": "string", "description": "Time scheduled for the task." },
        "day": { "type": "string", "description": "Day of the week scheduled." },
        "completed": { "type": "boolean", "description": "Completion flag." }
      },
      "required": ["id", "task", "time", "day", "completed"]
    },
    "ProgressEntry": {
      "title": "Quiz Performance Log",
      "description": "Records student practice quiz results to track progress.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "integer" },
        "total": { "type": "integer" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "subject", "score", "total", "date"]
    },
    "StudyDiagram": {
      "title": "Study Diagram",
      "description": "An AI-generated academic diagram or illustration saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the saved diagram." },
        "title": { "type": "string", "description": "Title of the diagram." },
        "prompt": { "type": "string", "description": "AI prompt used to generate this diagram." },
        "imageUrl": { "type": "string", "description": "The base64 encoded png image data url." },
        "explanation": { "type": "string", "description": "AI explanation and study points for the diagram." },
        "subject": { "type": "string", "description": "Academic subject category of the diagram." },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["id", "title", "imageUrl", "created_at"]
    },
    "StudyGroup": {
      "title": "Study Group",
      "description": "A collaborative study group created by a student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "subject": { "type": "string", "description": "Subject category of the study group." },
        "course": { "type": "string", "description": "Specific course or class name." }
      },
      "required": ["id", "name", "created_by", "created_at"]
    },
    "GroupQuestion": {
      "title": "Group Question",
      "description": "A question posted to the group, which can receive answers/comments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "asked_by": { "type": "string" },
        "asked_by_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "answers": {
          "type": "array",
          "description": "Array of answers posted by other members."
        }
      },
      "required": ["id", "title", "content", "asked_by", "asked_by_name", "created_at"]
    },
    "GroupSession": {
      "title": "Group Study Session",
      "description": "A scheduled virtual study session with RSVP capabilities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "integer" },
        "meeting_platform": { "type": "string" },
        "meeting_link": { "type": "string" },
        "created_by": { "type": "string" },
        "created_by_name": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "rsvps": {
          "type": "array",
          "description": "Attendee status markers."
        }
      },
      "required": ["id", "title", "topic", "date", "time", "duration", "meeting_platform", "created_by", "created_by_name", "created_at"]
    },
    "GroupMember": {
      "title": "Study Group Member",
      "description": "Details of a user belonging to a study group.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "joined_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "role", "joined_at"]
    },
    "GroupMessage": {
      "title": "Study Group Message",
      "description": "A real-time text message sent inside a study group.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_id", "user_name", "created_at"]
    },
    "GroupNote": {
      "title": "Group Shared Note",
      "description": "A collaborative group note readable and editable by all group members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "updated_by": { "type": "string" },
        "updated_by_name": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "updated_by", "updated_by_name", "updated_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Primary user profile document containing student information."
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "User's personal study notebooks collection."
    },
    "/users/{userId}/schedule/{scheduleId}": {
      "schema": "ScheduleItem",
      "description": "Planner calendar schedule list."
    },
    "/users/{userId}/progress/{progressId}": {
      "schema": "ProgressEntry",
      "description": "Log of practice quiz scores."
    },
    "/users/{userId}/diagrams/{diagramId}": {
      "schema": "StudyDiagram",
      "description": "User's personal saved study diagrams and illustrations."
    },
    "/groups/{groupId}": {
      "schema": "StudyGroup",
      "description": "Interactive, multi-user cooperative groups."
    },
    "/groups/{groupId}/members/{memberId}": {
      "schema": "GroupMember",
      "description": "A student who is joined in the group."
    },
    "/groups/{groupId}/messages/{messageId}": {
      "schema": "GroupMessage",
      "description": "A secure real-time message stream for the group."
    },
    "/groups/{groupId}/notes/{noteId}": {
      "schema": "GroupNote",
      "description": "Shared notebook for brainstorming and task distribution inside study groups."
    },
    "/groups/{groupId}/questions/{questionId}": {
      "schema": "GroupQuestion",
      "description": "Interactive questions and academic peer help boards within the group."
    },
    "/groups/{groupId}/sessions/{sessionId}": {
      "schema": "GroupSession",
      "description": "Scheduled virtual live study sessions for group participants."
    }
  }
}
