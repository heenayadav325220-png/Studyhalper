#!/bin/sh
# Lightweight gradle runner for CI environments when gradle-wrapper.jar is missing.
# Downloads Gradle distribution and runs the gradle binary.

set -e
GRADLE_VERSION="8.9"
GRADLE_BASE_DIR="$HOME/.gradle"
GRADLE_DIR="$GRADLE_BASE_DIR/gradle-$GRADLE_VERSION"
GRADLE_ZIP_URL="https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"

download_and_extract() {
  mkdir -p "$GRADLE_BASE_DIR"
  if [ ! -d "$GRADLE_DIR" ]; then
    echo "Downloading Gradle $GRADLE_VERSION..."
    curl -fsSL "$GRADLE_ZIP_URL" -o "$GRADLE_BASE_DIR/gradle-${GRADLE_VERSION}.zip"
    unzip -q "$GRADLE_BASE_DIR/gradle-${GRADLE_VERSION}.zip" -d "$GRADLE_BASE_DIR"
    rm "$GRADLE_BASE_DIR/gradle-${GRADLE_VERSION}.zip"
  fi
}

ensure_java() {
  if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
  else
    JAVACMD=$(command -v java || true)
  fi
  if [ -z "$JAVACMD" ]; then
    echo "ERROR: Java not found. Please install Java or set JAVA_HOME." >&2
    exit 1
  fi
}

# Download Gradle if needed
download_and_extract
ensure_java

# Execute Gradle
exec "$GRADLE_DIR/bin/gradle" "$@"
